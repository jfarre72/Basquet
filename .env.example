# Copiar este archivo a .env.local y completar los valores reales.
# En Vercel, configurar estas mismas variables en Settings → Environment Variables.

# URL del proyecto Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://<your-project>.supabase.co

# anon public API key del proyecto Supabase
VITE_SUPABASE_ANON_KEY=<paste-anon-key>
